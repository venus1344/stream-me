OME_HOST=stream.example.com
OME_WEBRTC_UDP_CANDIDATE_PORT=10000
OME_WEBRTC_TCP_CANDIDATE_PORT=10000
OME_WEBRTC_TCP_RELAY_PORT=3478

# OBS should publish to the relay on rtmp://HOST:1936/stream with this key.
# This matches the default app built into the alfg/nginx-rtmp image.
RELAY_INPUT_APP=stream
RELAY_INPUT_STREAM_KEY=input
RELAY_INPUT_HOST=127.0.0.1:1936

# The relay republishes to OME so your website player keeps working.
OME_RELAY_APP=app
OME_RELAY_STREAM_KEY=key
OME_RTMP_HOST=127.0.0.1:1935

# Optional YouTube restream target.
YOUTUBE_RTMPS_URL=rtmps://a.rtmp.youtube.com/live2
YOUTUBE_STREAM_KEY=
RESTREAM_CONTROL_PORT=8099
YOUTUBE_VIDEO_BITRATE_KBPS=6000
YOUTUBE_MAXRATE_KBPS=6000
YOUTUBE_BUFSIZE_KBPS=12000
YOUTUBE_AUDIO_BITRATE_KBPS=160
YOUTUBE_FPS=30
YOUTUBE_GOP_SECONDS=2
YOUTUBE_PRESET=veryfast
YOUTUBE_SCALE_HEIGHT=1080
